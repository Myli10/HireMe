<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.MainPageView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    x:DataType="vm:MainPageViewModel"
    Title="HireMe"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0.0" Color="#1A0040" />
            <GradientStop Offset="0.6" Color="#3A0078" />
            <GradientStop Offset="1.0" Color="#512BD4" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top bar: greeting + settings -->
        <Grid Grid.Row="0" Padding="24,52,24,0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label
                    Text="Hello 👋"
                    FontSize="15"
                    TextColor="#CCB8FF" />
                <Label
                    Text="{Binding Name}"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White" />
            </VerticalStackLayout>
            <Button
                Grid.Column="1"
                Padding="0"
                BackgroundColor="#3D2580"
                Command="{Binding SettingsCommand}"
                FontFamily="MaterialIcons"
                FontSize="22"
                Text="&#xe8b8;"
                TextColor="White"
                CornerRadius="24"
                WidthRequest="46"
                HeightRequest="46"
                VerticalOptions="Center" />
        </Grid>

        <!-- Center: Logo + tagline + stats card -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="20" Padding="24,0">

            <Image
                Source="hireme_logo.png"
                HeightRequest="130"
                WidthRequest="130"
                HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label
                    Text="HireMe"
                    FontSize="34"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="White" />
                <Label
                    Text="Your next job is closer than you think"
                    FontSize="14"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    TextColor="#CCB8FF" />
            </VerticalStackLayout>

            <!-- Card -->
            <Border
                BackgroundColor="#2D1A7A"
                Stroke="#5B3FBF"
                StrokeShape="RoundRectangle 18"
                Padding="24,18"
                HorizontalOptions="Fill">
                <Label
                    Text="Browse hundreds of local jobs,&#10;chat with managers directly,&#10;and land your next opportunity."
                    FontSize="14"
                    TextColor="#E8E0FF"
                    HorizontalTextAlignment="Center"
                    LineHeight="1.5" />
            </Border>
        </VerticalStackLayout>

        <!-- Bottom action button -->
        <VerticalStackLayout Grid.Row="2" Padding="24,0,24,40" Spacing="12">
            <Button
                Text="🔍  Find Your Job"
                Command="{Binding GoToFindJobCommand}"
                BackgroundColor="White"
                TextColor="#512BD4"
                CornerRadius="16"
                FontSize="18"
                FontAttributes="Bold"
                HeightRequest="58">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
