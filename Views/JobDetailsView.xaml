<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.JobDetailsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    xmlns:model="clr-namespace:FirebaseWorkout.Model"
    x:DataType="vm:JobDetailsViewModel"
    Title="Details"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            <!--  Title  -->
            <Label
                Text="Details"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#512BD4"
                Margin="0,10,0,16" />

            <!--  Details Card  -->
            <Border
                Padding="20"
                Stroke="#E0E0E0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1"
                BackgroundColor="#FAFAFA">
                <Border.Shadow>
                    <Shadow Brush="Gray" Offset="0,3" Radius="6" Opacity="0.12" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">

                    <Label
                        Text="{Binding SelectedWorkPlace.Name}"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#1A1A2E"
                        HorizontalOptions="Center" />

                    <Label
                        Text="{Binding SelectedWorkPlace.CreatedByUserName, StringFormat='Posted by: {0}'}"
                        FontSize="12"
                        TextColor="Gray"
                        HorizontalOptions="Center" />

                    <BoxView HeightRequest="1" Color="#E0E0E0" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Description:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label Text="{Binding SelectedWorkPlace.Description}" TextColor="#333" FontSize="15" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Address:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label Text="{Binding SelectedWorkPlace.Address}" TextColor="#333" FontSize="15" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Worker's Rating:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Border
                            BackgroundColor="#EEF2FF"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 10"
                            Padding="14,8"
                            HorizontalOptions="Start">
                            <Label
                                Text="{Binding StarRating}"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#3730A3" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Manager Phone Number:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label Text="{Binding SelectedWorkPlace.ManagerPhone}" TextColor="#333" FontSize="15" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Salary Per Hour:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label TextColor="#333" FontSize="15">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding SelectedWorkPlace.SalaryPerHour}" />
                                    <Span Text=" ₪ / hour" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Shift Hours:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label Text="{Binding SelectedWorkPlace.ShiftHours}" TextColor="#333" FontSize="15" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Opening Hours:" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
                        <Label Text="{Binding SelectedWorkPlace.OpeningHours}" TextColor="#333" FontSize="15" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!--  Action Buttons  -->
            <VerticalStackLayout Spacing="10" Margin="0,18,0,0">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="#512BD4"
                    HorizontalOptions="Center" />

                <Button
                    Text="{Binding FavoriteButtonText}"
                    Command="{Binding ToggleFavoriteCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="16"
                    HeightRequest="50" />

                <Button
                    Text="✍ Write a Review"
                    Command="{Binding AddReviewCommand}"
                    BackgroundColor="#2B0B98"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="16"
                    HeightRequest="50" />

                <Button
                    Text="💬 Chat with Manager"
                    Command="{Binding OpenChatCommand}"
                    IsVisible="{Binding IsNotCreator}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="16"
                    HeightRequest="50" />

                <Button
                    Text="{Binding ReportButtonText}"
                    Command="{Binding ReportJobCommand}"
                    IsVisible="{Binding IsNotCreator}"
                    IsEnabled="{Binding HasReported, Converter={StaticResource InvertedBoolConverter}}"
                    BackgroundColor="#B71C1C"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="15"
                    HeightRequest="46" />

                <Button
                    Text="Back To Find Job"
                    Command="{Binding BackToFindJobCommand}"
                    BackgroundColor="#DFD8F7"
                    TextColor="#512BD4"
                    CornerRadius="10"
                    FontSize="16"
                    HeightRequest="48" />

                <Button
                    Text="Go To Favorite Jobs"
                    Command="{Binding GoToFavoriteJobsCommand}"
                    BackgroundColor="#F5F5F5"
                    TextColor="#512BD4"
                    CornerRadius="10"
                    FontSize="16"
                    HeightRequest="48" />

                <!-- כפתורים לבעל המשרה בלבד -->
                <VerticalStackLayout IsVisible="{Binding IsCreator}" Spacing="10" Margin="0,8,0,0">
                    <BoxView HeightRequest="1" Color="#E0E0E0" />
                    <Label
                        Text="You posted this job"
                        FontSize="12"
                        TextColor="Gray"
                        HorizontalOptions="Center" />
                    <Button
                        Text="{Binding FilledButtonText}"
                        Command="{Binding ToggleFilledCommand}"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="15"
                        HeightRequest="48"
                        BackgroundColor="#E65100">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsFilled}" Value="True">
                                <Setter Property="BackgroundColor" Value="#388E3C" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button
                        Text="📩 View Applicant Chats"
                        Command="{Binding ViewApplicantChatsCommand}"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="16"
                        HeightRequest="48" />
                    <Button
                        Text="✏ Edit Job Details"
                        Command="{Binding EditJobCommand}"
                        BackgroundColor="#2B0B98"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="16"
                        HeightRequest="48" />
                    <Button
                        Text="🗑 Delete Job"
                        Command="{Binding DeleteJobCommand}"
                        BackgroundColor="#D32F2F"
                        TextColor="White"
                        CornerRadius="10"
                        FontSize="16"
                        HeightRequest="48" />
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!--  Reviews Section  -->
            <VerticalStackLayout Margin="0,24,0,20" Spacing="12">

                <Label
                    Text="Worker Reviews"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#512BD4" />

                <ActivityIndicator
                    IsRunning="{Binding IsLoadingReviews}"
                    IsVisible="{Binding IsLoadingReviews}"
                    Color="#512BD4"
                    HorizontalOptions="Center" />

                <Label
                    Text="No reviews yet — be the first!"
                    FontSize="14"
                    TextColor="Gray"
                    HorizontalOptions="Center"
                    IsVisible="{Binding HasReviews, Converter={StaticResource InvertedBoolConverter}}" />

                <CollectionView ItemsSource="{Binding Reviews}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Review">
                            <Border
                                Margin="0,4"
                                Padding="14,12"
                                Stroke="#E8E0F7"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="#F8F5FF">

                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding UserName}"
                                            FontAttributes="Bold"
                                            TextColor="#2B0B98"
                                            FontSize="14" />
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding Date}"
                                            TextColor="Gray"
                                            FontSize="12" />
                                    </Grid>
                                    <Border
                                        BackgroundColor="#EEF2FF"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 6"
                                        Padding="8,3"
                                        HorizontalOptions="Start">
                                        <Label
                                            Text="{Binding RatingBadge}"
                                            TextColor="#3730A3"
                                            FontAttributes="Bold"
                                            FontSize="13" />
                                    </Border>
                                    <Label
                                        Text="{Binding Text}"
                                        TextColor="#333"
                                        FontSize="14" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
