<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.AddJobView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    x:DataType="vm:AddJobViewModel"
    Title="Post a Job"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label
                Text="פרסם משרה"
                FontSize="26"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#512BD4"
                Margin="0,10,0,6" />

            <Label
                Text="שתף מקום עבודה עם הקהילה"
                FontSize="14"
                TextColor="Gray"
                HorizontalOptions="Center"
                Margin="0,0,0,10" />

            <!-- Job Name -->
            <Label Text="שם המשרה *" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="למשל: בריסטה בארקפה" Text="{Binding JobName}" FontSize="15" />
            </Border>

            <!-- Category -->
            <Label Text="קטגוריה" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="4,0" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Picker
                    Title="בחר קטגוריה"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding Category}"
                    FontSize="15" />
            </Border>

            <!-- Custom category (visible only when "אחר" is selected) -->
            <Border
                IsVisible="{Binding ShowCustomCategory}"
                Padding="12,10"
                Stroke="#512BD4"
                StrokeShape="RoundRectangle 8">
                <Entry
                    Placeholder="פרט את סוג המשרה (למשל: צילום, שיעורים פרטיים...)"
                    Text="{Binding CustomCategory}"
                    FontSize="15" />
            </Border>

            <!-- Description -->
            <Label Text="תיאור המשרה" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Editor
                    Placeholder="מה עושים שם? טיפים, אווירה, שעות..."
                    Text="{Binding Description}"
                    FontSize="15"
                    HeightRequest="90"
                    AutoSize="TextChanges" />
            </Border>

            <!-- Street Address -->
            <Label Text="כתובת (רחוב ומספר) *" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="למשל: רוטשילד 8" Text="{Binding Address}" FontSize="15" />
            </Border>

            <!-- City -->
            <Label Text="עיר *" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="4,0" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Picker
                    Title="בחר עיר..."
                    ItemsSource="{Binding IsraeliCities}"
                    SelectedItem="{Binding City}"
                    FontSize="15" />
            </Border>

            <!-- Manager Phone -->
            <Label Text="טלפון מנהל/ת" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="05X-XXXXXXX" Text="{Binding ManagerPhone}" Keyboard="Telephone" FontSize="15" />
            </Border>

            <!-- Salary Per Hour -->
            <Label Text="שכר לשעה (₪)" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="למשל: 40" Text="{Binding SalaryText}" Keyboard="Numeric" FontSize="15" />
            </Border>

            <!-- Shift Hours -->
            <Label Text="שעות משמרת" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="למשל: 09:00 - 17:00" Text="{Binding ShiftHours}" FontSize="15" />
            </Border>

            <!-- Opening Hours -->
            <Label Text="שעות פתיחה" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Entry Placeholder="למשל: 07:30 - 22:00" Text="{Binding OpeningHours}" FontSize="15" />
            </Border>

            <!-- Location on Map -->
            <Label Text="מיקום במפה (אופציונלי)" FontAttributes="Bold" TextColor="#512BD4" FontSize="14" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label
                    Grid.Column="0"
                    Text="{Binding LocationStatus}"
                    TextColor="Gray"
                    FontSize="13"
                    VerticalOptions="Center" />
                <Button
                    Grid.Column="1"
                    Text="📍 השתמש במיקום שלי"
                    Command="{Binding UseMyLocationCommand}"
                    BackgroundColor="#DFD8F7"
                    TextColor="#512BD4"
                    CornerRadius="8"
                    FontSize="13"
                    Padding="10,8" />
            </Grid>

            <!-- Loading -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#512BD4"
                HorizontalOptions="Center" />

            <!-- Buttons -->
            <Button
                Text="פרסם משרה"
                Command="{Binding SubmitJobCommand}"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="10"
                FontSize="17"
                FontAttributes="Bold"
                HeightRequest="52"
                Margin="0,10,0,0" />

            <Button
                Text="ביטול"
                Command="{Binding CancelCommand}"
                BackgroundColor="#F0F0F0"
                TextColor="#555"
                CornerRadius="10"
                FontSize="16"
                HeightRequest="48"
                Margin="0,0,0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
