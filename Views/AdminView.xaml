<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.AdminView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    x:DataType="vm:AdminViewModel"
    Title="Admin Panel"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label
                Text="Admin Panel"
                FontSize="26"
                FontAttributes="Bold"
                TextColor="#B71C1C"
                HorizontalOptions="Center"
                Margin="0,10,0,4" />

            <Label
                Text="Manage users and reported job listings."
                FontSize="14"
                TextColor="Gray"
                HorizontalOptions="Center"
                Margin="0,0,0,10" />

            <Button
                Text="👥 View Users"
                Command="{Binding NavigateToUsersListViewCommand}"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="10"
                FontSize="16"
                HeightRequest="52" />

            <Button
                Text="⚑ View Reported Jobs"
                Command="{Binding NavigateToReportedJobsCommand}"
                BackgroundColor="#B71C1C"
                TextColor="White"
                CornerRadius="10"
                FontSize="16"
                HeightRequest="52" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
