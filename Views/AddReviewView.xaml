<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.AddReviewView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    x:DataType="vm:AddReviewViewModel"
    Title="Write a Review"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Text="Write a Review"
                FontSize="26"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#512BD4"
                Margin="0,10,0,4" />

            <Label
                Text="{Binding WorkPlaceName}"
                FontSize="18"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#333"
                Margin="0,0,0,10" />

            <!-- Rating -->
            <Label Text="Your Rating" FontAttributes="Bold" TextColor="#512BD4" FontSize="15" />

            <Border
                BackgroundColor="#EEF2FF"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 12"
                Padding="24,12"
                HorizontalOptions="Center">
                <Label
                    Text="{Binding CurrentStars}"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#3730A3"
                    HorizontalOptions="Center" />
            </Border>

            <Border Padding="4,0" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Picker
                    Title="Choose rating (1-5)"
                    ItemsSource="{Binding RatingOptions}"
                    SelectedItem="{Binding SelectedRating}"
                    FontSize="16" />
            </Border>

            <!-- Review Text -->
            <Label Text="Your Review" FontAttributes="Bold" TextColor="#512BD4" FontSize="15" />
            <Border Padding="12,10" Stroke="#E0E0E0" StrokeShape="RoundRectangle 8">
                <Editor
                    Placeholder="Share your experience — hours, pay, manager, atmosphere..."
                    Text="{Binding ReviewText}"
                    FontSize="15"
                    HeightRequest="120"
                    AutoSize="TextChanges" />
            </Border>

            <!-- Loading -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#512BD4"
                HorizontalOptions="Center" />

            <!-- Buttons -->
            <Button
                Text="Submit Review"
                Command="{Binding SubmitReviewCommand}"
                BackgroundColor="#512BD4"
                TextColor="White"
                CornerRadius="10"
                FontSize="17"
                FontAttributes="Bold"
                HeightRequest="52"
                Margin="0,10,0,0" />

            <Button
                Text="Cancel"
                Command="{Binding CancelCommand}"
                BackgroundColor="#F0F0F0"
                TextColor="#555"
                CornerRadius="10"
                FontSize="16"
                HeightRequest="48"
                Margin="0,0,0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
