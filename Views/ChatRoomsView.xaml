<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FirebaseWorkout.Views.ChatRoomsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FirebaseWorkout.ViewModels"
    xmlns:model="clr-namespace:FirebaseWorkout.Model"
    x:DataType="vm:ChatRoomsViewModel"
    Title="Applicant Chats"
    BackgroundColor="White">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,10,0,16">
            <Label
                Text="Applicant Chats"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="#512BD4"
                HorizontalOptions="Center" />
            <Label
                Text="{Binding WorkPlaceName}"
                FontSize="14"
                TextColor="Gray"
                HorizontalOptions="Center" />
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#512BD4"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Participants}">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                    <Label Text="📭" FontSize="48" HorizontalOptions="Center" />
                    <Label
                        Text="No messages yet"
                        FontSize="16"
                        TextColor="Gray"
                        HorizontalOptions="Center" />
                    <Label
                        Text="When someone messages you about this job, they'll appear here."
                        FontSize="13"
                        TextColor="Gray"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:ChatParticipant">
                    <Border
                        Margin="0,6"
                        Padding="16,14"
                        Stroke="#E0E0E0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White">
                        <Border.Shadow>
                            <Shadow Brush="Gray" Offset="0,2" Radius="4" Opacity="0.1" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="3">
                                <Label
                                    Text="{Binding ApplicantName}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#1A1A2E" />
                                <Label
                                    Text="{Binding LastMessage}"
                                    FontSize="13"
                                    TextColor="Gray"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="1"
                                Text="Open Chat"
                                BackgroundColor="#512BD4"
                                TextColor="White"
                                CornerRadius="8"
                                FontSize="13"
                                Padding="12,8"
                                Clicked="OnOpenChatClicked" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.Row="2"
            Text="Back"
            Command="{Binding GoBackCommand}"
            BackgroundColor="#DFD8F7"
            TextColor="#512BD4"
            CornerRadius="10"
            FontSize="16"
            HeightRequest="48"
            Margin="0,10,0,10" />

    </Grid>
</ContentPage>
